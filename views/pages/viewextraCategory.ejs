<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>View Category</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

    <!-- Bootstrap (already using in your project) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            font-family: 'Poppins', sans-serif;
        }

        /* Breadcrumb */
        .page-breadcrumb {
            color: #fff;
            padding: 20px;
        }

        .breadcrumb {
            background: transparent;
            margin-bottom: 0;
        }

        .breadcrumb-item a {
            color: #60a5fa;
        }

        .breadcrumb-item.active {
            color: #9ca3af;
        }

        .page-title {
            color: #fff;
        }

        /* Card */
        .card {
            background: #0b1220;
            border-radius: 12px;
            box-shadow: 0 0 30px rgba(0,0,0,0.4);
            border: none;
            color: #fff;
        }

        .card-title {
            color: #fff;
            margin-bottom: 20px;
        }

        /* Table */
        .table {
            color: #fff;
            border-collapse: separate;
            border-spacing: 0 10px;
        }

        .table thead th {
            background: #111827;
            border: none;
            color: #cbd5e1;
            padding: 12px;
        }

        .table tbody tr {
            background: #111827;
            transition: 0.3s;
        }

        .table tbody tr:hover {
            background: #1f2937;
        }

        .table td {
            border: none;
            padding: 12px;
            vertical-align: middle;
        }

        /* Image */
        .table img {
            border-radius: 8px;
            object-fit: cover;
        }

        /* Buttons */
        .btn-primary {
            background: linear-gradient(90deg, #4f46e5, #3b82f6);
            border: none;
        }

        .btn-danger {
            background: linear-gradient(90deg, #ef4444, #dc2626);
            border: none;
        }

        .btn {
            border-radius: 6px;
            padding: 5px 12px;
            font-size: 13px;
        }
    </style>
</head>

<body>

<div class="page-wrapper">

    <!-- Breadcrumb -->
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex align-items-center">
                <h4 class="page-title">View Category</h4>

                <div class="ml-auto">
                    <nav>
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item active">View Category</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="container-fluid">

        <div class="row">
            <div class="col-12">

                <div class="card">
                    <div class="card-body">

                        <h5 class="card-title">Category Table</h5>

                        <div class="table-responsive">
                            <table class="table">

                                <thead>
                                    <tr>
                                        <th>Sr no.</th>
                                        <th>Category Icon</th>
                                        <th>Category Name</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% categories.forEach((category, index)=> { %>

                                        <tr>
                                            <td><%= index + 1 %></td>

                                            <td>
                                                <img src="/<%= category.image %>" width="50" height="50">
                                            </td>

                                            <td><%= category.name %></td>
                                            <td>
                                                <a href="/extracategory/editextraCategory/<%= category._id %>" class="btn btn-primary btn-sm col-4">Edit</a>
                                            </td>
                                        </tr>

                                    <% }); %>
                                </tbody>

                            </table>
                        </div>

                    </div>
                </div>

            </div>
        </div>

    </div>

</div>

</body>
</html>