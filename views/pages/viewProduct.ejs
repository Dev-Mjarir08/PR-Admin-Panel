<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>View Product</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            font-family: 'Poppins', sans-serif;
        }

        .page-breadcrumb {
            color: #fff;
            padding: 20px;
        }

        .breadcrumb {
            background: transparent;
        }

        .breadcrumb-item a {
            color: #60a5fa;
        }

        .breadcrumb-item.active {
            color: #9ca3af;
        }

        .page-title {
            color: #fff;
        }

        .card {
            background: #0b1220;
            border-radius: 12px;
            box-shadow: 0 0 30px rgba(0,0,0,0.4);
            border: none;
            color: #fff;
        }

        .table {
            color: #fff;
            border-collapse: separate;
            border-spacing: 0 10px;
        }

        .table thead th {
            background: #111827;
            border: none;
            color: #cbd5e1;
        }

        .table tbody tr {
            background: #111827;
            transition: 0.3s;
        }

        .table tbody tr:hover {
            background: #1f2937;
        }

        .table td {
            border: none;
            vertical-align: middle;
        }

        .table img {
            border-radius: 8px;
            object-fit: cover;
        }

        .btn-primary {
            background: linear-gradient(90deg, #4f46e5, #3b82f6);
            border: none;
        }

        .btn-danger {
            background: linear-gradient(90deg, #ef4444, #dc2626);
            border: none;
        }
    </style>
</head>

<body>

<div class="page-wrapper">

    <!-- Breadcrumb -->
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex align-items-center">
                <h4 class="page-title">View Product</h4>

                <div class="ml-auto">
                    <nav>
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item active">View Product</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">

                <h5 class="card-title">Product Table</h5>

                <div class="table-responsive">
                    <table class="table">

                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Category</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% products.forEach((product, index)=> { %>

                                <tr>
                                    <td><%= index + 1 %></td>

                                    <td>
                                        <img src="/<%= product.image %>" width="50" height="50">
                                    </td>

                                    <td><%= product.name %></td>
                                    <td>₹ <%= product.price %></td>
                                    <td><%= product.category?.name %></td>

                                    <td>
                                        <a href="/product/editproduct/<%= product._id %>" class="btn btn-primary btn-sm">Edit</a>

                                        <a href="/product/deleteproduct/<%= product._id %>" class="btn btn-danger btn-sm">Delete</a>
                                    </td>
                                </tr>

                            <% }) %>
                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    </div>

</div>

</body>
</html>